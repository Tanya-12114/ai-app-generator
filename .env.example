# --- Running with Docker Compose (recommended, zero manual DB setup) -------
# `docker compose up` already wires DATABASE_URL for you against the
# bundled postgres container. You only need to set NEXTAUTH_SECRET below,
# e.g. via a `.env` file next to docker-compose.yml (compose auto-loads it).
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- Running locally without Docker (npm run dev) ---------------------------
# Point this at any Postgres instance (local, Neon, Railway, Render...).
# Not needed/used when running via `docker compose up`.
DATABASE_URL="postgresql://app:app@localhost:5432/ai_app_generator"
